# Discord webhook (REQUIRED for non-dry-run posting).
DISCORD_WEBHOOK_URL=

# Optional: separate channel for the daily snapshot. If unset, falls back to DISCORD_WEBHOOK_URL.
DAILY_SNAPSHOT_DISCORD_WEBHOOK_URL=

# X (Twitter) v2 OAuth1.0a user-context credentials. Required only if
# daily_snapshot.enable_x is true and you're not running --dry-run.
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=

# Translation provider keys — only needed if you flip
# daily_snapshot.enable_jp_translation: true in config/settings.yaml.
# Off by default for Solana since token tickers are universal.
#   gemini     → GEMINI_API_KEY (free tier 1500 RPD; aistudio.google.com/apikey)
#   anthropic  → ANTHROPIC_API_KEY (paid)
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# Optional: identify your bot to GeckoTerminal's public API (no key needed,
# but a User-Agent helps if they ever rate-limit by client).
SOLANA_USER_AGENT=solana-daily-snapshot/0.1

LOG_LEVEL=INFO
DB_PATH=./data/snapshot.db
DRY_RUN=false
